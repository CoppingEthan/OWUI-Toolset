{
  "name": "owui-toolset-v2",
  "version": "2.0.0",
  "description": "External AI orchestration server for OpenWebUI with multi-provider LLM support, tool execution, and token tracking",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dashboard": "node src/dashboard/server.js",
    "dashboard:dev": "node --watch src/dashboard/server.js",
    "db:init": "node src/database/init.js",
    "test": "node --test tests/test-cost-calculator.js tests/test-format-conversion.js"
  },
  "keywords": [
    "openwebui",
    "llm",
    "anthropic",
    "llama-server",
    "ai-orchestration",
    "token-tracking"
  ],
  "author": "OWUI Toolset V2",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.3.3",
    "file-type": "^21.3.0",
    "markdown-pdf": "^11.0.0",
    "multer": "^2.0.2",
    "music-metadata": "^11.10.6",
    "openai": "^6.27.0",
    "sharp": "^0.34.5",
    "sql.js": "^1.10.3",
    "ssh2": "^1.17.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
